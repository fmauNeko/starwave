    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.0",
    "@snazzah/davey": "^0.1.9",
    "arkregex": "^0.0.6",
    "arktype": "^2.1.29",
    "bgutils-js": "3.2.0",
    "canvas": "^3.2.3",
    "discord-api-types": "^0.38.0",
    "discord.js": "^14.25.1",
    "googlevideo": "4.0.4",
    "jsdom": "29.1.1",
    "necord": "^6.11.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "youtubei.js": "17.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@necord/schematics": "1.3.8",
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.27",
    "@suites/di.nestjs": "3.1.0",
    "@suites/doubles.vitest": "3.1.0",
    "@suites/unit": "3.1.1",
